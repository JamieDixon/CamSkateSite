  "dependencies": {
    "jest": "^30.3.0",
    "prettier": "3.8.3"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.29.2",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.10"
  }
